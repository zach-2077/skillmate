{
  "name": "skills-gov",
  "version": "0.0.1",
  "description": "Full-screen TUI for managing agent skills",
  "type": "module",
  "bin": {
    "skills-gov": "./dist/cli.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "skills": "^1.5.1",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.3.3",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "packageManager": "pnpm@9.12.0"
}
