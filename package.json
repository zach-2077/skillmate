{
  "name": "skillmate",
  "version": "0.1.1",
  "description": "Full-screen TUI for managing agent skills",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zach-2077/skillmate.git"
  },
  "homepage": "https://github.com/zach-2077/skillmate#readme",
  "bugs": {
    "url": "https://github.com/zach-2077/skillmate/issues"
  },
  "type": "module",
  "bin": {
    "sm": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\"",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "marked": "^18.0.2",
    "marked-terminal": "^7.3.0",
    "react": "^18.3.1",
    "skills": "^1.5.1",
    "smol-toml": "^1.6.1",
    "xdg-basedir": "^5.1.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.3.3",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "packageManager": "pnpm@9.12.0"
}
